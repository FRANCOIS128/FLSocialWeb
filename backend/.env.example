# PostgreSQL connection string (e.g. from Neon). Local dev can use the same Neon URL.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
ACCESS_TOKEN_SECRET="replace-with-your-own-random-secret"
TOKEN_EXPIRES_IN="1d"
SALT_ROUNDS=10
PORT=9090
# 生产环境填写前端域名，逗号分隔可多个；留空则允许所有来源
CORS_ORIGIN=""
